generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  FREE
  PRO
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  name             String
  subscriptionTier SubscriptionTier   @default(FREE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  texts            Text[]
  sessions         DictationSession[]
  settings         UserSettings?
}

model Text {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String   @db.LongText
  level       String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    DictationSession[]

  @@index([userId, createdAt])
}

model DictationSession {
  id          String   @id @default(cuid())
  userId      String
  textId      String?
  title       String
  sourceText  String   @db.LongText
  userInput   String   @db.LongText
  language    String
  accuracy    Float    @default(0)
  wpm         Float?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        Text?    @relation(fields: [textId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  language      String   @default("English")
  targetLevel   String   @default("B2")
  speechRate    Float    @default(1)
  wordGap       Float    @default(0.5)
  enableAiHints Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
